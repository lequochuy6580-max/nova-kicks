# =============================================
# Nova Kicks - Environment Variables
# =============================================
# Sao chép file này thành .env.local và điền giá trị thực

# MongoDB Connection String
# - Local: mongodb://localhost:27017/Nova-kicks
# - Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/Nova-kicks
MONGODB_URI=mongodb://localhost:27017/Nova-kicks

# Base URL của ứng dụng (dùng cho client-side fetch)
# - Local: http://localhost:3000
# - Production: https://your-domain.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000
